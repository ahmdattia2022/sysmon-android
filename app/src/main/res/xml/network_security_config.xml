<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Router uses self-signed cert; allow cleartext + trust any cert for LAN IPs only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.100.1</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.100.254</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
